generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String       @id @default(cuid())
  username        String       @unique
  displayName     String?
  avatarUrl       String?
  bio             String?
  profileComplete Boolean      @default(false)
  createdAt       DateTime     @default(now())
  lastSeenAt      DateTime     @default(now())
  email           String       @unique
  firebaseUid     String       @unique
  role            Role         @default(USER)
  cards           Card[]
  decks           Deck[]
  cardUsageStats  UserCardUsage[]
  friendLinksA    Friendship[] @relation("FriendshipUserA")
  friendLinksB    Friendship[] @relation("FriendshipUserB")

  // Stats
  wins             Int     @default(0)
  losses           Int     @default(0)
  gamesPlayed      Int     @default(0)
  mmr              Int     @default(1000)
  favoriteChampion String?
  topCard1Id       String?
  topCard2Id       String?
  topCard3Id       String?
}

model Friendship {
  id        String   @id @default(cuid())
  userAId   String
  userBId   String
  createdAt DateTime @default(now())
  userA     User     @relation("FriendshipUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB     User     @relation("FriendshipUserB", fields: [userBId], references: [id], onDelete: Cascade)

  @@unique([userAId, userBId])
  @@index([userBId])
}

model Card {
  id           String         @id @default(cuid())
  publicCode   String         @unique
  status       CardStatus     @default(UNCLAIMED)
  claimedAt    DateTime?
  ownerId      String?
  definitionId String
  createdAt    DateTime       @default(now())
  definition   CardDefinition @relation(fields: [definitionId], references: [id])
  owner        User?          @relation(fields: [ownerId], references: [id])
  deckCards    DeckCard[]
  usageStats   UserCardUsage[]
}

model UserCardUsage {
  id         String   @id @default(cuid())
  userId     String
  cardId     String
  playCount  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  card       Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([userId, cardId])
  @@index([userId, playCount])
}

model CardDefinition {
  id          String     @id @default(cuid())
  type        CardType
  name        String
  description String
  rarity      CardRarity
  effectJson  Json?
  imageUrl    String?
  cards       Card[]
}

model Match {
  id        String   @id
  state     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  expiresAt DateTime
}

model Deck {
  id        String     @id @default(cuid())
  name      String
  ownerId   String
  owner     User       @relation(fields: [ownerId], references: [id])
  cards     DeckCard[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model DeckCard {
  id       String @id @default(cuid())
  deckId   String
  cardId   String
  position Int    @default(0)
  deck     Deck   @relation(fields: [deckId], references: [id], onDelete: Cascade)
  card     Card   @relation(fields: [cardId], references: [id])

  @@unique([deckId, cardId])
}

enum Role {
  USER
  ADMIN
}

enum CardType {
  CHARACTER
  ITEM
  SPELL
  TOOL
}

enum CardRarity {
  COMMON
  UNCOMMON
  RARE
  EPIC
  LEGENDARY
}

enum CardStatus {
  UNCLAIMED
  CLAIMED
  LOCKED
}
